@model NoticeBoard_frontend.ViewModels.AnnouncementFormViewModelBase
@{
    var categories = (IEnumerable<string>?)ViewBag.Categories ?? Enumerable.Empty<string>();
    var heading = (string?)ViewData["Heading"] ?? "Announcements";
    var formAction = (string?)ViewData["FormAction"] ?? "Index";
    var submitText = (string?)ViewData["SubmitText"] ?? "Save";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">@heading</h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to list</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="@formAction" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    @if (Model.Id.HasValue)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" maxlength="100" />
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Title" class="text-danger small"></span>
                            <small class="text-muted char-count" data-target="Title">0 / 100</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">
                            Description <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="4" maxlength="1000"></textarea>
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <small class="text-muted char-count" data-target="Description">0 / 1000</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label fw-semibold">
                            Category <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Category" class="form-select">
                            <option value="">Select category</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SubCategory" class="form-label fw-semibold">Subcategory</label>
                        <select asp-for="SubCategory"
                                class="form-select"
                                data-current-subcategory="@Model.SubCategory">
                            <option value="">Select category first</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Status" class="form-check-input" type="checkbox" />
                            <label asp-for="Status" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@submitText</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

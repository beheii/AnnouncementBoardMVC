@model NoticeBoard_frontend.ViewModels.AnnouncementIndexViewModel
@{
    ViewData["Title"] = "Announcements";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Announcements</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">+ Create announcement</a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <form id="filterForm" method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Category</label>
                <select name="category" id="filterCategory" class="form-select">
                    <option value="">All categories</option>
                    @foreach (var cat in Model.CategoryOptions.Select(x => x.Name).OrderBy(x => x))
                    {
                        <option value="@cat" selected="@(Model.CategoryFilter == cat ? "selected" : null)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Subcategory</label>
                <select name="subCategory" id="filterSubCategory" class="form-select" disabled>
                    <option value="">Select category</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Apply</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Announcements.Any())
{
    <div class="text-center text-muted py-5">
        <p class="fs-5">No announcements found.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var item in Model.Announcements)
        {
            <div class="col">
                <div class="card h-100 shadow-sm announcement-card"
                     role="button"
                     tabindex="0"
                     data-id="@item.Id"
                     data-title="@item.Title"
                     data-description="@item.Description"
                     data-status="@(item.Status ? "Active" : "Inactive")"
                     data-category="@item.Category"
                     data-subcategory="@(item.SubCategory ?? "")"
                     data-created="@item.CreatedDate.ToString("dd.MM.yyyy")"
                     data-updated="@(item.UpdatedDate?.ToString("dd.MM.yyyy") ?? "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@item.Title</h5>
                            @if (item.Status)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <p class="card-text text-muted">@item.Description</p>
                        <div class="mt-auto">
                            <small class="text-muted d-block">
                                <strong>Category:</strong> @item.Category
                                @if (!string.IsNullOrEmpty(item.SubCategory))
                                {
                                    <span> / @item.SubCategory</span>
                                }
                            </small>
                            <small class="text-muted">
                                <strong>Created:</strong> @item.CreatedDate.ToString("dd.MM.yyyy")
                            </small>
                            @if (item.UpdatedDate.HasValue)
                            {
                                <small class="text-muted d-block">
                                    <strong>Updated:</strong> @item.UpdatedDate.Value.ToString("dd.MM.yyyy")
                                </small>
                            }
                        </div>
                    </div>
                    @if (User.Identity?.IsAuthenticated == true && item.UserId == Model.CurrentUserId)
                    {
                        <div class="card-footer bg-transparent d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-fill">Edit</a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger flex-fill"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal"
                                    data-id="@item.Id"
                                    data-title="@item.Title">
                                Delete
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<div class="modal fade" id="announcementDetailsModal" tabindex="-1" aria-labelledby="announcementDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="announcementDetailsModalLabel">Announcement details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h4 id="detailsTitle" class="mb-3"></h4>
                <p id="detailsDescription" class="mb-3"></p>
                <div class="small text-muted">
                    <div><strong>Status:</strong> <span id="detailsStatus"></span></div>
                    <div><strong>Category:</strong> <span id="detailsCategory"></span></div>
                    <div><strong>Created:</strong> <span id="detailsCreated"></span></div>
                    <div id="detailsUpdatedRow" class="d-none"><strong>Updated:</strong> <span id="detailsUpdated"></span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="deleteModalTitle"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var detailsModalEl = document.getElementById("announcementDetailsModal");
            var detailsModal = new bootstrap.Modal(detailsModalEl);
            var cards = document.querySelectorAll(".announcement-card");

            function openDetails(card) {
                var category = card.getAttribute("data-category");
                var subCategory = card.getAttribute("data-subcategory");
                var categoryText = category + (subCategory ? " / " + subCategory : "");

                document.getElementById("detailsTitle").textContent = card.getAttribute("data-title");
                document.getElementById("detailsDescription").textContent = card.getAttribute("data-description");
                document.getElementById("detailsStatus").textContent = card.getAttribute("data-status");
                document.getElementById("detailsCategory").textContent = categoryText;
                document.getElementById("detailsCreated").textContent = card.getAttribute("data-created");

                var updated = card.getAttribute("data-updated");
                var updatedRow = document.getElementById("detailsUpdatedRow");
                if (updated) {
                    document.getElementById("detailsUpdated").textContent = updated;
                    updatedRow.classList.remove("d-none");
                } else {
                    document.getElementById("detailsUpdated").textContent = "";
                    updatedRow.classList.add("d-none");
                }

                detailsModal.show();
            }

            cards.forEach(function (card) {
                card.addEventListener("click", function (event) {
                    if (event.target.closest("a, button, form")) return;
                    openDetails(card);
                });

                card.addEventListener("keydown", function (event) {
                    if (event.key === "Enter" || event.key === " ") {
                        event.preventDefault();
                        openDetails(card);
                    }
                });
            });
        })();
    </script>
    <script>
        var deleteModal = document.getElementById("deleteModal");
        deleteModal.addEventListener("show.bs.modal", function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute("data-id");
            var title = button.getAttribute("data-title");
            document.getElementById("deleteModalTitle").textContent = title;
            document.getElementById("deleteForm").action = "/Announcements/Delete/" + id;
        });
    </script>
    <script>
        (function () {
            var options = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryOptions));
            var catEl = document.getElementById("filterCategory");
            var subEl = document.getElementById("filterSubCategory");
            if (!catEl || !subEl) return;

            var savedSub = "@(Model.SubCategoryFilter ?? "")";

            function fillSub() {
                var catName = catEl.value;
                var found = null;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].Name === catName) { found = options[i]; break; }
                }
                var subs = found ? (found.SubCategories || []) : [];

                subEl.innerHTML = "";
                var ph = document.createElement("option");
                ph.value = "";

                if (!catName) {
                    ph.textContent = "Select category";
                    subEl.disabled = true;
                } else if (subs.length === 0) {
                    ph.textContent = "No subcategories";
                    subEl.disabled = true;
                } else {
                    ph.textContent = "All subcategories";
                    subEl.disabled = false;
                }
                subEl.appendChild(ph);

                for (var j = 0; j < subs.length; j++) {
                    var opt = document.createElement("option");
                    opt.value = subs[j];
                    opt.textContent = subs[j];
                    if (savedSub && savedSub === subs[j]) opt.selected = true;
                    subEl.appendChild(opt);
                }

                savedSub = "";
            }

            catEl.addEventListener("change", function () {
                savedSub = "";
                fillSub();
            });

            fillSub();
        })();
    </script>
}

@model NoticeBoard_frontend.Models.UpdateAnnouncementViewModel
@{
    ViewData["Title"] = "Редагувати оголошення";
    var categories = (IEnumerable<string>?)ViewBag.Categories ?? Enumerable.Empty<string>();
    var categoryOptions = (IEnumerable<NoticeBoard_frontend.Models.CategoryOption>?)ViewBag.CategoryOptions
        ?? Enumerable.Empty<NoticeBoard_frontend.Models.CategoryOption>();
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Редагувати оголошення</h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад до списку</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">
                            Заголовок <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" maxlength="100" />
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Title" class="text-danger small"></span>
                            <small class="text-muted char-count" data-target="Title">0 / 100</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">
                            Опис <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="4" maxlength="1000"></textarea>
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <small class="text-muted char-count" data-target="Description">0 / 1000</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label fw-semibold">
                            Категорія <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Category" class="form-select">
                            <option value="">Оберіть категорію</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SubCategory" class="form-label fw-semibold">Підкатегорія</label>
                        <select asp-for="SubCategory" class="form-select">
                            <option value="">Спочатку оберіть категорію</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Status" class="form-check-input" type="checkbox" />
                            <label asp-for="Status" class="form-check-label">Активне</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Зберегти</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.querySelectorAll('[maxlength]').forEach(function (el) {
            var max = parseInt(el.getAttribute('maxlength'), 10);
            var counter = document.querySelector('.char-count[data-target="' + el.id + '"]');

            function update() {
                var len = el.value.length;
                if (counter) counter.textContent = len + ' / ' + max;

                if (len >= max) {
                    el.classList.add('is-invalid');
                    if (counter) counter.classList.add('text-danger');
                } else {
                    el.classList.remove('is-invalid');
                    if (counter) counter.classList.remove('text-danger');
                }
            }

            el.addEventListener('input', update);
            el.addEventListener('paste', function () { setTimeout(update, 0); });
            update();
        });
    </script>
    <script>
        (function () {
            var options = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryOptions));
            var catEl = document.getElementById("Category");
            var subEl = document.getElementById("SubCategory");
            if (!catEl || !subEl) return;

            function fillSub() {
                var catName = catEl.value;
                var keep = subEl.value;
                var found = null;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].Name === catName) { found = options[i]; break; }
                }
                var subs = found ? (found.SubCategories || []) : [];

                subEl.innerHTML = "";
                var ph = document.createElement("option");
                ph.value = "";
                if (!catName) {
                    ph.textContent = "Спочатку оберіть категорію";
                    subEl.disabled = true;
                } else if (subs.length === 0) {
                    ph.textContent = "Немає підкатегорій";
                    subEl.disabled = true;
                } else {
                    ph.textContent = "(Необов'язково) Оберіть підкатегорію";
                    subEl.disabled = false;
                }
                subEl.appendChild(ph);

                for (var j = 0; j < subs.length; j++) {
                    var opt = document.createElement("option");
                    opt.value = subs[j];
                    opt.textContent = subs[j];
                    if (keep && keep === subs[j]) opt.selected = true;
                    subEl.appendChild(opt);
                }
            }

            catEl.addEventListener("change", function () {
                subEl.value = "";
                fillSub();
            });
            fillSub();
        })();
    </script>
}
